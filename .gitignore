# Python virtual environment — never commit this
venv/
.venv/

# Python caches
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/

# Environment variables / secrets
.env

# OS junk
.DS_Store

# Claude Code local tooling config — not part of the project
.claude/

