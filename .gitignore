# Python virtual environment — never commit this
venv/
.venv/

# Python caches
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/

# Environment variables / secrets
.env

# OS junk
.DS_Store

# Claude Code local tooling config — not part of the project
.claude/

# OSMnx cache — downloaded API responses, regenerated on demand
cache/

# Raw GPX = third-party recorded tracks (Wikiloc) — don't republish
data/raw/

# Processed data: keep the derived feature table (our own work), ignore the rest
data/processed/*
!data/processed/features.csv

# Trained model artifacts — committed so the deployed app can load them
models/*
!models/rf_model.pkl
!models/model_meta.json

# Generated plots — regenerated by notebooks
plots/

# Jupyter
*.ipynb_checkpoints
